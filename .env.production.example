# ─── Copie este arquivo para .env.production e preencha os valores ────────────
# Nunca commite .env.production no git.

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Usado pelo Prisma (serviço 'postgres' na rede interna do Docker)
DATABASE_URL="postgresql://gosf:TROQUE_AQUI@postgres:5432/gosf_db"
POSTGRES_USER=gosf
POSTGRES_PASSWORD=TROQUE_AQUI
POSTGRES_DB=gosf_db

# ─── Redis ────────────────────────────────────────────────────────────────────
# Usado pelo Bull (serviço 'redis' na rede interna do Docker)
REDIS_URL="redis://:TROQUE_AQUI@redis:6379"
REDIS_PASSWORD=TROQUE_AQUI

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Gere segredos fortes: openssl rand -base64 64
JWT_SECRET="gere-um-segredo-forte-aqui"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="gere-outro-segredo-forte-aqui"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3001
API_URL="https://api.seudominio.com"
WEB_URL="https://seudominio.com"

# Usado como build arg no Dockerfile.web (baked no bundle Next.js)
NEXT_PUBLIC_API_URL="https://api.seudominio.com/api/v1"

# Portas expostas pelo docker-compose.prod.yml
WEB_PORT=3000

# ─── IA (Anthropic) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
AI_MODEL="claude-sonnet-4-6"

# ─── E-mail (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="GOSF <noreply@seudominio.com>"
APP_URL="https://seudominio.com"
