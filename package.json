{
  "name": "gosf",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @gosf/database generate",
    "db:migrate": "pnpm --filter @gosf/database migrate:dev",
    "db:push": "pnpm --filter @gosf/database db:push",
    "db:studio": "pnpm --filter @gosf/database studio",
    "db:seed": "pnpm --filter @gosf/database seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2"
  }
}
