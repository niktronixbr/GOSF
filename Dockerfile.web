# ─── Stage 1: base ────────────────────────────────────────────────────────────
FROM node:20-alpine AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN npm install -g pnpm@10.33.0

# ─── Stage 2: deps — instala todas as dependências no Linux ───────────────────
FROM base AS deps
WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc .pnpmfile.cjs ./
COPY apps/web/package.json                ./apps/web/
COPY apps/api/package.json                ./apps/api/
COPY packages/database/package.json       ./packages/database/
COPY packages/shared/package.json         ./packages/shared/
COPY packages/database/prisma             ./packages/database/prisma/

ENV PRISMA_CLI_BINARY_TARGETS="linux-musl-openssl-3.0.x"
RUN pnpm install --frozen-lockfile

# ─── Stage 3: builder — build Next.js standalone ──────────────────────────────
FROM base AS builder
WORKDIR /app

ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

ARG GIT_SHA
ENV GIT_SHA=$GIT_SHA

# Copia node_modules instalados no Linux
COPY --from=deps /app/node_modules                      ./node_modules
COPY --from=deps /app/apps/web/node_modules             ./apps/web/node_modules
COPY --from=deps /app/packages/database/node_modules    ./packages/database/node_modules

# Copia código-fonte
COPY tsconfig.base.json                   ./
COPY package.json pnpm-workspace.yaml     ./
COPY apps/web                             ./apps/web
COPY packages/database                    ./packages/database
COPY packages/shared                      ./packages/shared

# Build Next.js (gera .next/standalone)
RUN pnpm --filter @gosf/web build

# ─── Stage 4: runner — imagem mínima com output standalone ────────────────────
FROM node:20-alpine AS runner
ENV NODE_ENV=production
WORKDIR /app

# O Next.js standalone cria um servidor Node.js auto-contido
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static     ./apps/web/.next/static
COPY --from=builder /app/apps/web/public           ./apps/web/public

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# O servidor standalone fica em apps/web/server.js dentro do standalone
CMD ["node", "apps/web/server.js"]
